{
  "name": "erp-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npx vite --host 0.0.0.0",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm ci && npx vite build",
    "seed": "node server/seed.js",
    "start": "node server/index.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4"
  }
}
